# FinPal server — copy to server/.env and replace every placeholder.
# Prisma reads this file from server/ (not .env.local — that is for Next.js).
#
# Supabase Dashboard → Connect → ORMs / Prisma:
#   https://supabase.com/docs/guides/database/prisma
#   - DATABASE_URL = Transaction pooler (port 6543) + ?pgbouncer=true
#   - DIRECT_URL = Session pooler (port 5432) — migrations and db push
# Use the exact URIs from the dashboard; user is often postgres.[PROJECT_REF]@aws-*-[region].pooler.supabase.com
#
# Upstash: Redis → copy rediss:// URL into REDIS_URL

# ─── Database (Supabase) — paste from Connect; replace [YOUR-PASSWORD] with DB password ───
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Redis (Upstash) ───
REDIS_URL="rediss://default:[PASSWORD]@[HOST].upstash.io:6379"

# ─── JWT Secrets (generate: openssl rand -hex 32) ───
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ─── AI Provider ───
# Options: "nvidia" (default), "gemini", or "anthropic"
AI_PROVIDER="nvidia"

# ─── NVIDIA / DeepSeek (required when AI_PROVIDER=nvidia) ───
NVIDIA_API_KEY="nvapi-..."

# ─── Google Gemini (required when AI_PROVIDER=gemini) ───
GEMINI_API_KEY="your-gemini-api-key"

# ─── Anthropic (required when AI_PROVIDER=anthropic) ───
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Supabase Storage (same project) ───
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."

# ─── Firebase Cloud Messaging (optional for local dev) ───
FIREBASE_PROJECT_ID="finpal-xxxxx"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@finpal-xxxxx.iam.gserviceaccount.com"

# ─── Server ───
PORT=3000
NODE_ENV=development
