generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  email             String   @unique @db.VarChar(255)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  name              String   @db.VarChar(100)
  monthlyIncome     Decimal? @map("monthly_income") @db.Decimal(12, 2)
  currency          String   @default("LKR") @db.VarChar(10)
  fcmToken          String?  @map("fcm_token") @db.VarChar(255)
  notificationPrefs Json     @default("{}") @map("notification_prefs") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  wallets         Wallet[]
  transactions    Transaction[]
  budgets         Budget[]
  goals           Goal[]
  companionMemory CompanionMemory[]
  aiCheckins      AiCheckin[]
  ingestionLogs   IngestionLog[]
  reconciliations Reconciliation[]

  @@map("users")
}

model Wallet {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String   @db.VarChar(100)
  type            String   @db.VarChar(20)
  startingBalance Decimal  @map("starting_balance") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  reconciliations Reconciliation[]

  @@index([userId])
  @@map("wallets")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  walletId        String   @map("wallet_id") @db.Uuid
  amount          Decimal  @db.Decimal(12, 2)
  signedAmount    Decimal  @map("signed_amount") @db.Decimal(12, 2)
  type            String   @db.VarChar(10)
  merchant        String?  @db.VarChar(150)
  category        String   @db.VarChar(50)
  status          String   @default("pending") @db.VarChar(20)
  source          String   @db.VarChar(20)
  rawInput        String?  @map("raw_input") @db.Text
  aiConfidence    Float?   @map("ai_confidence")
  metadata        Json     @default("{}") @db.JsonB
  transactionDate DateTime @map("transaction_date") @db.Timestamptz()
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, transactionDate(sort: Desc)])
  @@index([userId, category])
  @@index([walletId, status])
  @@index([userId, source])
  @@map("transactions")
}

model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  category    String   @db.VarChar(50)
  amountLimit Decimal  @map("amount_limit") @db.Decimal(12, 2)
  period      String   @db.VarChar(10)
  rollover    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
  @@index([userId])
  @@map("budgets")
}

model Goal {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String    @db.VarChar(100)
  targetAmount  Decimal   @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(12, 2)
  targetDate    DateTime? @map("target_date") @db.Date
  status        String    @default("active") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("goals")
}

model CompanionMemory {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String   @db.VarChar(30)
  key        String   @db.VarChar(100)
  value      String   @db.Text
  confidence Float    @default(0.5)
  lastSeen   DateTime @map("last_seen") @db.Timestamptz()
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, type])
  @@map("companion_memory")
}

model AiCheckin {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(20)
  content   String    @db.Text
  readAt    DateTime? @map("read_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, type])
  @@map("ai_checkins")
}

model IngestionLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  sourceType   String   @map("source_type") @db.VarChar(20)
  rawPayload   String   @map("raw_payload") @db.Text
  status       String   @default("queued") @db.VarChar(20)
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ingestion_logs")
}

model Reconciliation {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  walletId        String   @map("wallet_id") @db.Uuid
  statedBalance   Decimal  @map("stated_balance") @db.Decimal(12, 2)
  computedBalance Decimal  @map("computed_balance") @db.Decimal(12, 2)
  discrepancy     Decimal  @db.Decimal(12, 2)
  reconciledAt    DateTime @map("reconciled_at") @db.Timestamptz()

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, reconciledAt(sort: Desc)])
  @@index([walletId])
  @@map("reconciliations")
}
