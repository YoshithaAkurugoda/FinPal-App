{
  "name": "@finpal/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:workers": "node dist/workers/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39",
    "@finpal/shared": "*",
    "@prisma/client": "^6.5",
    "@supabase/supabase-js": "^2.49",
    "bcrypt": "^6.0",
    "bullmq": "^5.42",
    "cors": "^2.8",
    "dotenv": "^16.4.7",
    "express": "^4.21",
    "express-rate-limit": "^7.5",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1",
    "ioredis": "^5.6",
    "jsonwebtoken": "^9.0",
    "multer": "^1.4",
    "pdf-parse": "^1.1",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0",
    "@types/cors": "^2.8",
    "@types/express": "^5.0",
    "@types/jsonwebtoken": "^9.0",
    "@types/multer": "^1.4",
    "@types/node": "^22.13",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.5",
    "tsx": "^4.19",
    "typescript": "^5.7"
  }
}
